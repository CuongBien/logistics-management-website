{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "oms-route": {
        "ClusterId": "oms-cluster",
        "Match": {
          "Path": "/api/oms/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/oms" },
          { "RequestHeader": "X-Forwarded-Prefix", "Set": "/api/oms" }
        ]
      },
      "wms-route": {
        "ClusterId": "wms-cluster",
        "Match": {
          "Path": "/api/wms/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/wms" },
          { "RequestHeader": "X-Forwarded-Prefix", "Set": "/api/wms" }
        ]
      },
      "oms-swagger-route": {
        "ClusterId": "oms-cluster",
        "Match": {
          "Path": "/swagger/oms/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "swagger/{**catch-all}" },
          { "RequestHeader": "X-Forwarded-Prefix", "Set": "/api/oms" }
        ]
      },
      "wms-swagger-route": {
        "ClusterId": "wms-cluster",
        "Match": {
          "Path": "/swagger/wms/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "swagger/{**catch-all}" },
          { "RequestHeader": "X-Forwarded-Prefix", "Set": "/api/wms" }
        ]
      }
    },
    "Clusters": {
      "oms-cluster": {
        "Destinations": {
          "oms-destination": {
            "Address": "http://localhost:5000"
          }
        }
      },
      "wms-cluster": {
        "Destinations": {
          "wms-destination": {
            "Address": "http://localhost:5051"
          }
        }
      }
    }
  }
}
