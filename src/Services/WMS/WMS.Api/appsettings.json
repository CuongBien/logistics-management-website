{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://localhost:5341" } }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "JwtOptions": {
    "Authority": "http://keycloak:8080/realms/logistics_realm",
    "Audience": "oms-client",
    "RequireHttpsMetadata": false
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=56432;Database=lms_wms_dev;Username=postgres;Password=postgres"
  },
  "MessageBroker": {
    "RabbitMQ": {
      "Host": "localhost",
      "Username": "lms",
      "Password": "lms123"
    }
  },
  "SwaggerOptions": {
    "ServerBasePath": "/api/wms"
  }
}
