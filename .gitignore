# Combined .gitignore
bin/
obj/
.vs/
.vscode/
/note/
/tools/
.gemini/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build Results of an ATL Project
[Bb]uild[Ll]og.htm

