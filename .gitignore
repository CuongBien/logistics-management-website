_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# Default appsettings.Development.json is often ignored in real projects to avoid committing secrets
# But for this onboarding task, we commit it as a template. To ignore it, uncomment below:
**/appsettings.Development.json

# Secrets
secrets.json
local_credentials.txt
# Rider
.idea/
*.sln.iml

.cursorrules

# Application logs
seq_logs.json
*.log

git
main

plans/
tests/
!src/Tests/
!src/Tests/**
src/Tests/**/bin/
src/Tests/**/obj/
