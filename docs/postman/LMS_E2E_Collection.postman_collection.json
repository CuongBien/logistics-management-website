  "item": [
    {
      "name": "STEP 1 – Tạo đơn hàng (Ordering)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Auto-reset run state before creating a new order",
              "pm.collectionVariables.set('orderId', '');",
              "pm.collectionVariables.set('receiptId', '');",
              "pm.collectionVariables.set('sourceShipmentNo', '');",
              "pm.collectionVariables.set('outboundOrderId', '');",
              "pm.environment.set('orderId', '');",
              "pm.environment.set('receiptId', '');",
              "pm.environment.set('sourceShipmentNo', '');",
              "pm.environment.set('outboundOrderId', '');",
              "",
              "// Decode token for ownership fields",
              "const token = pm.collectionVariables.get('token') || pm.environment.get('token');",
              "if (token) {",
              "  const payload = JSON.parse(atob(token.split('.')[1]));",
              "  pm.collectionVariables.set('consignorId', payload.sub);",
              "  pm.collectionVariables.set('customerId', payload.sub);",
              "  pm.environment.set('customerId', payload.sub || '');",
              "  const tenant = payload.tenant_id || payload.tenant || 'default-tenant';",
              "  pm.collectionVariables.set('tenantId', tenant);",
              "  pm.environment.set('tenantId', tenant);",
              "  console.log('Reset vars + token decoded. sub=', payload.sub, 'tenant=', tenant);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200/201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
              "const body = pm.response.json();",
              "const id = body?.value ?? body?.id ?? body;",
              "pm.collectionVariables.set('orderId', String(id));",
              "pm.environment.set('orderId', String(id));",
              "console.log('✅ orderId saved:', id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{oms_url}}/api/Orders", "host": ["{{oms_url}}"], "path": ["api", "Orders"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"waybillCode\": \"WB-{{$randomInt}}\",\n  \"consignorId\": \"{{consignorId}}\",\n  \"skuCodes\": [\n    \"{{skuCode}}\"\n  ],\n  \"weight\": 1.5,\n  \"shippingFee\": 35000,\n  \"codAmount\": 500000,\n  \"note\": \"Handle with care\",\n  \"consignee\": {\n    \"fullName\": \"Nguyen Van A\",\n    \"phone\": \"0901234567\",\n    \"address\": {\n      \"street\": \"123 Nguyen Trai\",\n      \"city\": \"Ho Chi Minh\",\n      \"state\": \"HCM\",\n      \"country\": \"Vietnam\",\n      \"zipCode\": \"70000\"\n    }\n  }\n}"
        }
      },
      "response": []
    },
    {
      "name": "STEP 1b – Pickup hàng (Ordering)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200/201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
              "console.log('✅ Order moved to PickedUp');"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{oms_url}}/api/orders/{{orderId}}/actions/pickup",
          "host": ["{{oms_url}}"],
          "path": ["api", "orders", "{{orderId}}", "actions", "pickup"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"driverId\": \"driver_01\"\n}"
        }
      },
      "response": []
    },
    {
      "name": "STEP 2a – Tạo phiếu nhập kho (Warehouse)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200/201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
              "const body = pm.response.json();",
              "const receiptId = body?.value ?? body?.id ?? body;",
              "pm.collectionVariables.set('receiptId', String(receiptId));",
              "pm.environment.set('receiptId', String(receiptId));",
              "const orderId = pm.collectionVariables.get('orderId');",
              "pm.collectionVariables.set('sourceShipmentNo', `ASN-${orderId}`);",
              "pm.environment.set('sourceShipmentNo', `ASN-${orderId}`);",
              "console.log('✅ receiptId saved:', receiptId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{wms_url}}/api/inbound/receipts", "host": ["{{wms_url}}"], "path": ["api", "inbound", "receipts"] },
        "body": {
          "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"tenantId\": \"{{tenantId}}\",\n  \"customerId\": \"{{customerId}}\",\n  \"sourceShipmentNo\": \"ASN-{{orderId}}\"\n}"
        }
      },
      "response": []
    },
    {
      "name": "STEP 2b – Nhân viên kho xác nhận nhận hàng (Warehouse)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200/201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
              "const orderId = pm.collectionVariables.get('orderId');",
              "const receiptId = pm.collectionVariables.get('receiptId');",
              "pm.test('orderId variable exists', () => pm.expect(orderId).to.be.a('string').and.not.empty);",
              "pm.test('receiptId variable exists', () => pm.expect(receiptId).to.be.a('string').and.not.empty);",
              "console.log('🔎 STEP2b orderId=', orderId, 'receiptId=', receiptId);",
              "console.log('✅ InboundReceipt marked as Received');"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{wms_url}}/api/inbound/receipts/{{receiptId}}/receive",
          "host": ["{{wms_url}}"],
          "path": ["api", "inbound", "receipts", "{{receiptId}}", "receive"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"tenantId\": \"{{tenantId}}\",\n  \"skuCode\": \"{{skuCode}}\",\n  \"binCode\": \"BIN-A1-01\",\n  \"scannedBy\": \"{{customerId}}\"\n}"
        }
      },
      "response": []
    },
    {
      "name": "STEP 2c – Tạo Outbound Order Draft (Warehouse)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const base = pm.collectionVariables.get('wms_url') || pm.environment.get('wms_url') || '';",
              "console.log('STEP 2c resolved URL:', pm.request.url.toString());",
              "console.log('STEP 2c wms_url base:', base);",
              "if (base === 'http://localhost:5200' || base === 'http://127.0.0.1:5200') {",
              "  console.warn('Fix wms_url: use http://localhost:5200/api/warehouse (local BFF), not gateway root.');",
              "}",
              "if (base === 'http://localhost:8000' || base === 'http://127.0.0.1:8000') {",
              "  console.warn('Docker BFF needs prefix: http://localhost:8000/api/warehouse');",
              "}",
              "if ((base.includes(':5200') || base.includes(':8000')) && !base.includes('/api/warehouse')) {",
              "  console.warn('Gateway URLs must include /api/warehouse — see collection description.');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 404) {",
              "  console.error('STEP 2c got 404 — routing/build issue (not orderId/body). Checklist:\\n1) wms_url per collection description (Docker BFF = http://localhost:8000/api/warehouse)\\n2) docker compose build warehouse.api && up -d warehouse.api\\n3) Swagger on WMS: POST /api/outbound/orders exists at http://localhost:5051/swagger');",
              "}",
              "pm.test('Status 200/201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
              "const body = pm.response.json();",
              "let oid = body;",
              "if (typeof body !== 'string') {",
              "  oid = body?.value ?? body?.id ?? body;",
              "}",
              "pm.collectionVariables.set('outboundOrderId', String(oid));",
              "pm.environment.set('outboundOrderId', String(oid));",
              "console.log('✅ outboundOrderId saved:', oid);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{wms_url}}/api/outbound/orders", "host": ["{{wms_url}}"], "path": ["api", "outbound", "orders"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"destinationWarehouseId\": \"11111111-1111-1111-1111-111111111111\",\n  \"lines\": [\n    { \"skuCode\": \"{{skuCode}}\", \"requestedQty\": 1 }\n  ]\n}"
        }
      },
      "response": []
    },
    {
      "name": "STEP 2d – Get Outbound Order (Warehouse)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200/201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
              "const body = pm.response.json();",
              "const expectedOrderId = String(pm.collectionVariables.get('orderId')).toLowerCase();",
              "pm.test('orderId matches run', () => pm.expect(String(body.orderId).toLowerCase()).to.eql(expectedOrderId));",
              "console.log('✅ Outbound order:', body.id, 'status=', body.status);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{wms_url}}/api/outbound/orders/{{outboundOrderId}}",
          "host": ["{{wms_url}}"],
          "path": ["api", "outbound", "orders", "{{outboundOrderId}}"]
        }
      },
      "response": []
    },
    {
      "name": "STEP 3 – Phân loại / Xuất kho (Warehouse)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const req = JSON.parse(pm.request.body.raw);",
              "const expectedOrderId = pm.collectionVariables.get('orderId');",
              "pm.test('Sort uses current orderId', () => pm.expect(req.orderId).to.eql(expectedOrderId));",
              "pm.test('Status 200/201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
              "console.log('🔎 STEP3 request orderId=', req.orderId, 'expected=', expectedOrderId);",
              "console.log('✅ Order sorted! ShipmentSortedIntegrationEvent published → Saga → AwaitingDispatch');"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{wms_url}}/api/outbound/sort", "host": ["{{wms_url}}"], "path": ["api", "outbound", "sort"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"destinationWarehouseId\": \"11111111-1111-1111-1111-111111111111\",\n  \"tenantId\": \"{{tenantId}}\",\n  \"customerId\": \"{{customerId}}\",\n  \"sourceShipmentNo\": \"{{sourceShipmentNo}}\"\n}"
        }
      },
      "response": []
    },
    {
      "name": "STEP 4 – Verify: Kiểm tra trạng thái Order (Ordering)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200/201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
              "const body = pm.response.json();",
              "const status = body.value?.status;",
              "console.log('📦 Order status:', status);",
              "pm.test('Order status exists', () => pm.expect(status).to.be.a('string').and.not.empty);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{oms_url}}/api/Orders/{{orderId}}",
          "host": ["{{oms_url}}"],
          "path": ["api", "Orders", "{{orderId}}"]
        }
      },
      "response": []
    },
    {
      "name": "STEP QA – Invalid receive endpoint on Ordering returns 404",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 404 Not Found', () => pm.response.to.have.status(404));",
              "console.log('✅ QA check passed: POST /actions/receive returned 404 as expected');",
              "console.log('QA response body:', pm.response.text());"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{oms_url}}/api/orders/{{orderId}}/actions/receive",
          "host": ["{{oms_url}}"],
          "path": ["api", "orders", "{{orderId}}", "actions", "receive"]
        },
        "body": {
          "mode": "raw",
          "raw": "{}"
        }
      },
      "response": []
    }
  ]
}
