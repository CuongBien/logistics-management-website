    {
      "name": "STEP 4 – Verify: Kiểm tra trạng thái Order (Ordering)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "const val = body.value;",
              "const status = val?.status;",
              "console.log('📦 Order status:', status);",
              "pm.test('Order status is AwaitingDispatch', () => pm.expect(status).to.eql('AwaitingDispatch'));",
              "const sub = pm.collectionVariables.get('consignorId');",
              "if (sub) {",
              "  pm.test('createdByOperatorId matches JWT sub', () => pm.expect(val.createdByOperatorId).to.eql(sub));",
              "  pm.test('updatedByOperatorId matches JWT sub', () => pm.expect(val.updatedByOperatorId).to.eql(sub));",
              "} else {",
              "  console.log('⚠️ consignorId not set; skip actor assertions');",
              "}",
              "const c = val?.consignee;",
              "if (c && c.address) {",
              "  pm.collectionVariables.set('e2eConsigneeFullName', c.fullName);",
              "  pm.collectionVariables.set('e2eConsigneePhone', c.phone);",
              "  pm.collectionVariables.set('e2eConsigneeStreet', c.address.street);",
              "  pm.collectionVariables.set('e2eConsigneeCity', c.address.city);",
              "  pm.collectionVariables.set('e2eConsigneeState', c.address.state);",
              "  pm.collectionVariables.set('e2eConsigneeCountry', c.address.country);",
              "  pm.collectionVariables.set('e2eConsigneeZipCode', c.address.zipCode);",
              "  console.log('📌 Stored inline consignee snapshot for STEP 4b parity');",
              "}"
            ]
