{
  "info": {
    "name": "Logistics E2E – Full Flow",
    "_postman_id": "lms-e2e-collection-v1",
    "description": "Postman Collection kiểm thử End-to-End toàn bộ luồng vận chuyển: Tạo đơn → Nhập kho → Phân loại xuất kho.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "oms_url", "value": "http://localhost:5000", "type": "string" },
    { "key": "wms_url", "value": "http://localhost:5051", "type": "string" },
    { "key": "token",   "value": "eyJhbGciOiJSUzI1NiIsInR5cCIgOiAiSldUIiwia2lkIiA6ICJPdmtKWV9WeDhSTk5CaXp3ZGh4TXRMdGVlVGUtWmhxT253dUNmRDVwYktVIn0..NpFtldxOAWisnkz83eUJEIrRZycJM-4ZcBNzICeW82kQIHbsbJR6aA8AcpuTNc0n_56cpJ5RjH28iR2funjQ53tMVexoThipIteWFkGyYkghJ6xX6_V_0JSSZyhn_rU6P61Gi5nUvOFMyKAkx_Ch0mUZ2a8TaNtoWaREyeVecviKbk8GhWu2l76GU2mq-Ifzvur95jvH9qxszONWGhfAmmIX5RtQNY90uJEN8cq-otmRzXXb9u1oDhyZU_f-si-DuL6LQfUNglt1CF-xfuKskv5FvOrDSFDDwrYiIADIqq4TcwVunU5gyCGBqQiM2PLZ9HkWuIr-Pyb_I4a_YG-HFw", "type": "string", "description": "Paste JWT Bearer Token vào đây sau khi lấy từ Keycloak" },
    { "key": "orderId",    "value": "", "type": "string" },
    { "key": "receiptId",  "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "eyJhbGciOiJSUzI1NiIsInR5cCIgOiAiSldUIiwia2lkIiA6ICJPdmtKWV9WeDhSTk5CaXp3ZGh4TXRMdGVlVGUtWmhxT253dUNmRDVwYktVIn0..NpFtldxOAWisnkz83eUJEIrRZycJM-4ZcBNzICeW82kQIHbsbJR6aA8AcpuTNc0n_56cpJ5RjH28iR2funjQ53tMVexoThipIteWFkGyYkghJ6xX6_V_0JSSZyhn_rU6P61Gi5nUvOFMyKAkx_Ch0mUZ2a8TaNtoWaREyeVecviKbk8GhWu2l76GU2mq-Ifzvur95jvH9qxszONWGhfAmmIX5RtQNY90uJEN8cq-otmRzXXb9u1oDhyZU_f-si-DuL6LQfUNglt1CF-xfuKskv5FvOrDSFDDwrYiIADIqq4TcwVunU5gyCGBqQiM2PLZ9HkWuIr-Pyb_I4a_YG-HFw", "type": "string" }]
  },
  "item": [
    {
      "name": "STEP 1 – Tạo đơn hàng (Ordering)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Tự động decode JWT để lấy 'sub' làm consignorId",
              "const token = pm.collectionVariables.get('token');",
              "if (token) {",
              "  const payload = JSON.parse(atob(token.split('.')[1]));",
              "  pm.collectionVariables.set('consignorId', payload.sub);",
              "  console.log('👤 consignorId (sub):', payload.sub);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "const id = pm.response.json();",
              "pm.collectionVariables.set('orderId', id);",
              "console.log('✅ orderId saved:', id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{oms_url}}/api/Orders", "host": ["{{oms_url}}"], "path": ["api", "Orders"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"waybillCode\": \"WB-{{$randomInt}}\",\n  \"consignorId\": \"{{consignorId}}\",\n  \"weight\": 1.5,\n  \"shippingFee\": 35000,\n  \"codAmount\": 500000,\n  \"note\": \"Handle with care\",\n  \"consignee\": {\n    \"fullName\": \"Nguyen Van A\",\n    \"phone\": \"0901234567\",\n    \"address\": {\n      \"street\": \"123 Nguyen Trai\",\n      \"city\": \"Ho Chi Minh\",\n      \"state\": \"HCM\",\n      \"country\": \"Vietnam\",\n      \"zipCode\": \"70000\"\n    }\n  }\n}"
        }
      },
      "response": []
    },
    {
      "name": "STEP 2a – Tạo phiếu nhập kho (Warehouse)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "const id = pm.response.json();",
              "pm.collectionVariables.set('receiptId', id);",
              "console.log('✅ receiptId saved:', id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{wms_url}}/api/inbound/receipts", "host": ["{{wms_url}}"], "path": ["api", "inbound", "receipts"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\"\n}"
        }
      },
      "response": []
    },
    {
      "name": "STEP 2b – Nhân viên kho xác nhận nhận hàng (Warehouse)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "console.log('✅ InboundReceipt marked as Received');"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [],
        "url": {
          "raw": "{{wms_url}}/api/inbound/receipts/{{receiptId}}/receive",
          "host": ["{{wms_url}}"],
          "path": ["api", "inbound", "receipts", "{{receiptId}}", "receive"]
        }
      },
      "response": []
    },
    {
      "name": "STEP 2c – [Manual] Fake hàng lên kệ (SQL via docker exec)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "http://localhost", "host": ["localhost"] },
        "description": "BƯỚC THỦ CÔNG – Chạy lệnh này trong Terminal trước khi qua Step 3:\n\ndocker exec -it lms-postgres psql -U postgres -d lms_wms_dev -c \"UPDATE \\\"Bins\\\" SET \\\"CurrentOrderId\\\" = '{{orderId}}' WHERE \\\"Id\\\" = '44444444-4444-4444-4444-444444444444';\"\n\nLệnh này gán hàng của đơn {{orderId}} lên kệ BIN-A1-01."
      },
      "response": []
    },
    {
      "name": "STEP 3 – Phân loại / Xuất kho (Warehouse)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "console.log('✅ Order sorted! ShipmentSortedIntegrationEvent published → Saga → AwaitingDispatch');"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{wms_url}}/api/outbound/sort", "host": ["{{wms_url}}"], "path": ["api", "outbound", "sort"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"destinationWarehouseId\": \"48b030da-e7ad-452f-90db-ddb01a613583\"\n}"
        }
      },
      "response": []
    },
    {
      "name": "STEP 4 – Verify: Kiểm tra trạng thái Order (Ordering)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "console.log('📦 Order status:', JSON.stringify(body, null, 2));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{oms_url}}/api/Orders/{{orderId}}",
          "host": ["{{oms_url}}"],
          "path": ["api", "Orders", "{{orderId}}"]
        }
      },
      "response": []
    }
  ]
}
