              "const expectedOrderId = pm.collectionVariables.get('orderId');",
              "// Find shipment where DestinationId is our destination warehouse and it's from the original warehouse",
              "const targetShipment = shipments.find(s => s.destinationId === '48b030da-e7ad-452f-90db-ddb01a613583');",
